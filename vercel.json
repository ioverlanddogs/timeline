{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "nodeVersion": "20.x",
  "buildCommand": "pnpm -w run vercel:build",
  "installCommand": "pnpm -w run vercel:install",
  "framework": "nextjs",
  "headers": [
    {
      "source": "/api/:path*",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, must-revalidate" }
      ]
    }
  ],
  "outputDirectory": "apps/web/.next"
}
